{
  "name": "planbuddy-backend",
  "description": "COMPLERE FULL BACKEND 100% REAL SYSTEM PRODYUCITON ",
  "author": "sijeeshmiziha",
  "keywords": ["microservice", "monorepo", "typescript"],
  "private": true,
  "license": "ISC",
  "engineStrict": true,
  "engines": {
    "node": ">=22.14.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rimraf ./apps/**/dist ./libs/**/dist ./apps/**/coverage ./apps/**/node_modules ./libs/**/node_modules node_modules .nx",
    "commit": "git-cz",
    "codegen:type": "graphql-codegen --config codegen.type.yaml -w",
    "codegen:hook": "graphql-codegen --config codegen.hook.yaml -w"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/helloplanbuddy-cmd/PlanBuddy-Backend-Productivity_R2"
  },
  "workspaces": ["apps/*", "libs/*"],
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    }
  },
  "lint-staged": {
    "{apps,libs}/**/src/**/*.{ts,tsx}": ["eslint {apps,libs}/**/src/**/*.{ts,tsx} --fix-dry-run", "prettier --write"]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@graphql-codegen/cli": "^5.0.5",
    "@graphql-codegen/typescript": "^4.1.5",
    "@graphql-codegen/typescript-resolvers": "^4.4.4",
    "@graphql-codegen/client-preset": "^4.8.0",
    "@graphql-codegen/typescript-operations": "^4.6.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@parcel/watcher": "^2.5.1",
    "@types/jest": "^29.5.14",
    "@types/lodash": "^4.17.16",
    "@types/luxon": "^3.4.2",
    "@typescript-eslint/eslint-plugin": "~8.0.1",
    "@typescript-eslint/parser": "~8.0.1",
    "commitizen": "^4.3.1",
    "commitlint-config-gitmoji": "^2.3.1",
    "cz-customizable": "^7.4.0",
    "eslint": "~8.57.0",
    "husky": "^9.1.4",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.0",
    "nx": "^20.6.3",
    "rimraf": "^6.0.1",
    "prettier": "~3.3.3",
    "prettier-plugin-tailwindcss": "~0.6.6",
    "ts-jest": "^29.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "luxon": "^3.5.0"
  }
}
