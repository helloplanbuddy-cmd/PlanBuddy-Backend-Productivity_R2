{
  "name": "planbuddy-v9",
  "version": "9.0.0",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --verbose",
    "test:financial": "jest --verbose --testPathPattern=financial-idempotency",
    "test:concurrency": "jest --verbose --testPathPattern=concurrency",
    "test:integration:idempotency-key-validation": "jest --runInBand --verbose --testPathPattern=tests/integration/idempotency-key-validation.test.js",
    "test:integration:refund-race-condition": "jest --runInBand --verbose --testPathPattern=tests/integration/refund-race-condition.test.js",
    "workers": "node workers/index.js",
    "worker:webhook": "node workers/start-webhook.js",
    "worker:refund": "node workers/start-refund.js",
    "worker:email": "node workers/start-email.js",
    "worker:scheduler": "node workers/start-scheduler.js"
  },
  "dependencies": {
    "bullmq": "^5.76.5",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "express-rate-limit": "^8.4.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.0.0",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.0",
    "uuid": "^9.0.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^6.3.0",
    "typescript": "^5.9.3"
  }
}
