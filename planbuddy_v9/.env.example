# PlanBuddy Backend .env.example (copy to .env)
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:pass@localhost:5432/planbuddy_dev
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_URL=redis://localhost:6379/1
JWT_SECRET=your_jwt_secret_here_min_64_chars_in_prod
JWT_EXPIRY=24h
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info
METRICS_ALLOWED_IPS=127.0.0.1,::1

# Fintech Upgrade
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/TEAM/WEBHOOK_SECRET
